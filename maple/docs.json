{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Wajihni",
  "colors": {
    "primary": "#9A3412",
    "light": "#EA580C",
    "dark": "#9A3412"
  },
  "favicon": "/favicon.svg",
  "contextual": {
   "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
